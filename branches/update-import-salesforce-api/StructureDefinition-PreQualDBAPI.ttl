       fhir:l <http://hl7.org/v3>
     ] ;
     fhir:name [ fhir:v "RIM Mapping" ]
  ] ) ; # 
  fhir:kind [ fhir:v "logical"] ; # 
  fhir:abstract [ fhir:v false] ; # 
